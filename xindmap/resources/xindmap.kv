<RootWidget>:
    input_widget: input_widget
    mind_map_widget: mind_map_widget
    output_widget: output_widget

    FloatLayout:
        size: root.size
        pos: root.pos

        MindMapWidget:
            id: mind_map_widget

            size_hint: (None, None)

            size: root.size
            pos: root.pos

        InputWidget:
            id: input_widget

            size_hint: (None, None)

            width: root.width - 10
            height: 20

            pos: 10, 5

        OutputWidget:
            id: output_widget

            size_hint: (None, None)

            width: root.width - 10
            height: 20

            pos: 10, 25

<InputWidget>:
    input_label: input_label

    Label:
        id: input_label

        pos: root.pos
        size: self.texture_size

<OutputWidget>:
    output_label: output_label

    Label:
        id: output_label

        pos: root.pos
        size: self.texture_size

        markup: True

<MindMapWidget>:
    scatter: scatter

    Scatter:
        id: scatter

        size: root.size
        pos: root.pos

        do_rotation: False

<MindNodeWidget>:
    label: label

    Label:
        id: label

        size: self.texture_size
        center_x: root.center_x
        center_y: root.center_y - self.font_size / 2

        text: ''
        halign: 'center'
        valgin: 'middle'

